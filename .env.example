# Αντιγραφή σε .env — ΜΗΝ ανεβάζετε το .env στο git.

# Υποχρεωτικά
DB_SERVER=
DB_DATABASE=ergani-karta
DB_USERNAME=
DB_PASSWORD=
DB_ODBC_DRIVER=ODBC Driver 17 for SQL Server

FLASK_SECRET_KEY=
PORT=5051
FLASK_DEBUG=1

# Σύνδεση UI (υποχρεωτικό εκτός FLASK_DEBUG — σε debug προεπιλογή admin/ergani)
KARTA_OFFICE_LOGIN_USER=
KARTA_OFFICE_LOGIN_PASSWORD=

# Ergani API (προαιρετικά — credentials ανά κατάστημα στη βάση)
ERGANI_API_BASE_URL=https://eservices.yeka.gr/WebservicesAPI/Api/
ERGANI_USERNAME=
ERGANI_PASSWORD=
ERGANI_USERTYPE=02

# Integration POST /api/work-card/event — υποχρεωτικό όταν FLASK_DEBUG=0
WORK_CARD_API_KEY=
WORK_CARD_DEFAULT_EMPLOYER_AFM=
WORK_CARD_DEFAULT_BRANCH_AA=0

# Telegram Bot (BotFather) — ειδοποιήσεις ληπτών καταστήματος
# Webhook: POST https://<domain>/api/telegram/webhook
TELEGRAM_BOT_TOKEN=

# Δημόσιο URL εφαρμογής (σύνδεσμοι Telegram)
PUBLIC_BASE_URL=https://erganios.gr

# Περιοδικός συγχρονισμός (Windows Task Scheduler — scripts/setup_scheduled_sync_task.ps1)
# Κάθε 10 λεπτά (:00, :10, :20, …): ωράριο + πραγματική σήμερα για όλα τα καταστήματα
KARTA_SCHEDULED_SYNC_ENABLED=1

# Προαιρετικό: προστασία όλων των /api/* (header X-Office-Token)
# KARTA_OFFICE_TOKEN=

CATALOG_DATABASE=ergani_ii
