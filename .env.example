# Αντιγραφή σε .env — ΜΗΝ ανεβάζετε το .env στο git.

# Υποχρεωτικά
DB_SERVER=
DB_DATABASE=ergani-karta
DB_USERNAME=
DB_PASSWORD=
DB_ODBC_DRIVER=ODBC Driver 17 for SQL Server

FLASK_SECRET_KEY=
PORT=5051
FLASK_DEBUG=1

# Ergani API (προαιρετικά — credentials ανά κατάστημα στη βάση)
ERGANI_API_BASE_URL=https://eservices.yeka.gr/WebservicesAPI/Api/
ERGANI_USERNAME=
ERGANI_PASSWORD=
ERGANI_USERTYPE=02

# Integration POST /api/work-card/event — υποχρεωτικό όταν FLASK_DEBUG=0
WORK_CARD_API_KEY=
WORK_CARD_DEFAULT_EMPLOYER_AFM=
WORK_CARD_DEFAULT_BRANCH_AA=0

# Telegram Bot (BotFather) — ειδοποιήσεις ληπτών καταστήματος
# Webhook: POST https://<domain>/api/telegram/webhook
TELEGRAM_BOT_TOKEN=

# Προαιρετικό: προστασία όλων των /api/* (header X-Office-Token)
# KARTA_OFFICE_TOKEN=

CATALOG_DATABASE=ergani_ii
